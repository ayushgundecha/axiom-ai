# Axiom-AI Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Axiom Server ---
AXIOM_HOST=0.0.0.0
AXIOM_PORT=8000

# --- Todo App ---
AXIOM_TODO_APP_URL=http://localhost:3000

# --- AxiomChat (deterministic mini-Slack environment) ---
AXIOM_AXIOMCHAT_APP_URL=http://localhost:3100
# Shared secret gating GET /api/_oracle/state. Must match the server's
# AXIOMCHAT_ORACLE_TOKEN. Override both in any real deployment.
AXIOM_AXIOMCHAT_ORACLE_TOKEN=axiom-oracle-dev-token

# --- Logging ---
# console (dev, colorful) or json (production, structured)
AXIOM_LOG_LEVEL=info
AXIOM_LOG_FORMAT=console

# --- Storage ---
AXIOM_SCREENSHOT_DIR=./trajectories
AXIOM_TRAJECTORY_DIR=./trajectories

# --- Sessions ---
AXIOM_MAX_SESSION_AGE_SECONDS=3600
