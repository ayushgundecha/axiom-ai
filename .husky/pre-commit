#!/bin/sh

echo "Running pre-commit checks..."

# Run linting
echo "  Linting..."
make lint 2>/dev/null
if [ $? -ne 0 ]; then
    echo "  Lint failed. Fix errors before committing."
    exit 1
fi

# Run type checking
echo "  Type checking..."
make typecheck 2>/dev/null
if [ $? -ne 0 ]; then
    echo "  Type check failed. Fix type errors before committing."
    exit 1
fi

# Tests disabled during active development — run manually with: make test
# make test 2>/dev/null

echo "All pre-commit checks passed."
