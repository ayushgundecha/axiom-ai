#!/bin/sh

echo "Running pre-push checks..."

echo "  Linting..."
make lint 2>/dev/null
if [ $? -ne 0 ]; then
    echo "  Lint failed. Fix errors before pushing."
    exit 1
fi

echo "  Type checking..."
make typecheck 2>/dev/null
if [ $? -ne 0 ]; then
    echo "  Type check failed. Fix type errors before pushing."
    exit 1
fi

# Tests disabled during active development — run manually with: make test
# make test 2>/dev/null

echo "All pre-push checks passed."
